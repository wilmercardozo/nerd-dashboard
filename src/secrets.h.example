// Plantilla de secretos. Copiar a src/secrets.h (en .gitignore) y completar.
//
// Solo necesario para desarrollo sin portal cautivo (hardcodear WiFi).
// En produccion, la config se carga desde LittleFS:/config.json via portal web.
//
// Para usarlos, define USE_SECRETS en build_flags y #include "secrets.h" donde aplique.

#define SECRET_WIFI_SSID   "MiRedWiFi"
#define SECRET_WIFI_PASS   "MiContrasena"

// Anthropic Admin API key (Modulo 2). Generar en console.anthropic.com.
#define SECRET_ADMIN_KEY   "sk-ant-admin-..."
